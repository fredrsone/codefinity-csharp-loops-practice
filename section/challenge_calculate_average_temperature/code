/*
Task
Write a program that calculates the average temperature from an array of integers.

Use a for loop to sum all values in the temps array.
Divide the sum by the number of elements in temps to find the average.
Return the average as a double value.
*/
using System;

namespace ConsoleApp
{
    public class Program
    {
        public static void Main()
        {
            int[] temperatures = { 72, 68, 75, 70, 69 };
            double average = CalculateAverageTemperature(temperatures);
            Console.WriteLine("Average temperature: " + average);
        }

        public static double CalculateAverageTemperature(int[] temps)
        {
            // Write your code here
            int sum = 0;
            double avg = 0;
            for (int i = 0; i < temps.Length; i++)
            {
                sum += temps[i];
            }
            avg = (double)sum / temps.Length;
            return avg;
        }
    }
}
