using System;

namespace ConsoleApp
{
    public class Program
    {
        public static void Main()
        {
            int secretNumber = 5;
            int[] guesses = { 2, 3, 5 };
            int index = 0;
            bool guessedCorrectly = false;

            do
            {
                int currentGuess = guesses[index];
                string result;

                if (currentGuess == secretNumber)
                {
                    guessedCorrectly = true;
                    result = "You guessed it!";
                }
                else
                {
                    result = "Try again.";
                }

                Console.WriteLine("Guessing number: " + currentGuess);
                Console.WriteLine(result);

                index++;
            }
            while (!guessedCorrectly && index < guesses.Length);
        }

        // Added for testing
        public static void RunGuessingGame(int secretNumber, int[] guesses)
        {
            int index = 0;
            bool guessedCorrectly = false;
            do
            {
                int currentGuess = guesses[index];
                string result;

                if (currentGuess == secretNumber)
                {
                    guessedCorrectly = true;
                    result = "You guessed it!";
                }
                else
                {
                    result = "Try again.";
                }

                Console.WriteLine("Guessing number: " + currentGuess);
                Console.WriteLine(result);

                index++;
            }
            while (!guessedCorrectly && index < guesses.Length);
        }
    }
}